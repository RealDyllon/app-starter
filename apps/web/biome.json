{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.css",
			"**/*.js",
			"**/*.json",
			"**/*.jsonc",
			"**/*.jsx",
			"**/*.ts",
			"**/*.tsx",
			"**/*.html",
			"!**/coverage/**/*",
			"!**/dist/**/*",
			"!**/dist-ssr/**/*",
			"!**/.nitro/**/*",
			"!**/.output/**/*",
			"!**/.tanstack/**/*",
			"!**/.vinxi/**/*",
			"!**/.wrangler/**/*",
			"!**/node_modules/**/*",
			"!**/.cta.json",
			"!**/playwright-report/**/*",
			"!**/test-results/**/*",
			"!**/drizzle/meta/**/*",
			"!**/src/i18n/paraglide/**/*",
			"!**/src/i18n/project.inlang/.meta.json",
			"!**/src/routeTree.gen.ts"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
